# SeaBoat 生产环境变量文件
# 文件位置：/home/wwwroot/yunpingtai.cc/.env
# 
# 用途：由 systemd 服务加载，供 Django 和其他应用使用
# 权限：chmod 600 .env（只有 www 用户可读）
#
# ===== 重要：请立即修改以下值 =====

# 1. Django 密钥（用 python -c "import secrets; print(secrets.token_urlsafe(50))" 生成）
SECRET_KEY=your_secure_generated_key_here_minimum_50_characters

# 2. 数据库密码（在宝塔面板创建数据库时设置）
DB_PASSWORD=Y6GwK3SkDcw55WNn

# 3. 数据库配置
# 选项A：MySQL
DB_ENGINE=django.db.backends.mysql
DB_NAME=seaboat_prod
DB_USER=seaboat_user
DB_HOST=localhost
DB_PORT=3306

# 选项B：PostgreSQL（注释掉选项A 如果使用此选项）
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=seaboat_prod
# DB_USER=seaboat_user
# DB_HOST=localhost
# DB_PORT=5432

# 4. Django 配置
DJANGO_SETTINGS_MODULE=seadrone.settings_prod
DEBUG=False
ALLOWED_HOSTS=yunpingtai.cc,www.yunpingtai.cc,127.0.0.1,localhost

# 5. CORS 配置（逗号分隔）
CORS_ALLOWED_ORIGINS=https://yunpingtai.cc,https://www.yunpingtai.cc

# 6. 邮件配置（可选）
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@example.com
EMAIL_HOST_PASSWORD=your_email_password
DEFAULT_FROM_EMAIL=noreply@yunpingtai.cc

# 7. 文件上传限制（字节）
FILE_UPLOAD_MAX_MEMORY_SIZE=524288000

# 8. 日志级别
LOG_LEVEL=INFO

# 8.1 短信验证码配置（阿里云短信服务）
# 开发调试：设为 true，不真实下发短信，会在接口响应里返回 debugCode
# 生产上线：务必设为 false
SMS_MOCK_ENABLED=false

# 阿里云短信 SDK 凭证（必填）
ALIYUN_SMS_ACCESS_KEY_ID=LTAI5tQW2mr4XRQyvnkzikcf
ALIYUN_SMS_ACCESS_KEY_SECRET=Piqa080QqcHtClbtowHct6rK1O7GeL

# 短信签名与模板（必填，模板需包含 code 参数）
ALIYUN_SMS_SIGN_NAME=速通互联验证服务
ALIYUN_SMS_TEMPLATE_CODE=100001
ALIYUN_SMS_SCHEME_NAME=请替换为阿里云短信认证方案名称

# 可选：短信参数
SMS_CODE_LENGTH=6
SMS_CODE_EXPIRE_SECONDS=300
SMS_SEND_COOLDOWN_SECONDS=60
ALIYUN_SMS_ENDPOINT=dypnsapi.aliyuncs.com

# 9. 时区和语言
LANGUAGE_CODE=zh-hans
TIME_ZONE=Asia/Shanghai

# 10. 服务器配置
SERVER_PROTOCOL=https
SERVER_HOST=yunpingtai.cc
SERVER_PORT=443

# 11. 缓存配置（可选）
CACHE_BACKEND=django.core.cache.backends.locmem.LocMemCache
# 或 Redis
# CACHE_BACKEND=django.core.cache.backends.redis.RedisCache
# CACHE_LOCATION=redis://127.0.0.1:6379/1

# 12. Gunicorn 配置
GUNICORN_WORKERS=4
GUNICORN_WORKER_CLASS=sync
GUNICORN_WORKER_CONNECTIONS=1000
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=50

# 13. 日期格式（可选）
USE_TZ=True
USE_I18N=True

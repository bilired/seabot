# 【生产】环境变量 - yunpingtai.cc

# 应用部署基础路径（如部署在子目录 /admin，则设置为 /admin/）
VITE_BASE_URL = /

# API 地址前缀（不要带 /api，接口文件已包含 /api 前缀）
VITE_API_URL = https://yunpingtai.cc

# 应用标题
VITE_APP_TITLE = SeaBoat Dashboard - 海上无人船智能管理系统

# 删除 console 日志
VITE_DROP_CONSOLE = true

# 请求超时时间（毫秒）
VITE_REQUEST_TIMEOUT = 30000

# 日志级别（warn, error）
VITE_LOG_LEVEL = warn
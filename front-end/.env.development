# 【开发】环境变量

# 应用部署基础路径（如部署在子目录 /admin，则设置为 /admin/）
VITE_BASE_URL = /

# API 请求基础路径（开发环境设置为 / 使用代理，生产环境设置为完整后端地址）
VITE_API_URL = /

# 代理目标地址（开发环境通过 Vite 代理转发请求到此地址，解决跨域问题）
# 改为本地 Django 后端地址
VITE_API_PROXY_URL = http://localhost:8000

# Delete console
VITE_DROP_CONSOLE = false

# Mapbox token（前端地图）
# 示例: pk.xxxxx
VITE_MAPBOX_TOKEN =pk.eyJ1IjoiaGFua3NnYW8yMjExIiwiYSI6ImNtZzQzN3Q4cTFob3IycnEydGc1a2hmMmYifQ.Iys4mJ4-5OHRNeyFmWCOfw